    .lab-brand-text { display: none; }
    @media (min-width: 640px) { .lab-brand-text { display: inline; } }
    .lab-powered {
      font-size: 10px;
      color: rgba(255,255,255,0.35);
      white-space: nowrap;
      letter-spacing: .03em;
      display: none;
    }
    @media (min-width: 640px) { .lab-powered { display: inline; } }
    .lab-powered strong { color: #00d4a8; font-weight: 600; }

    .lab-divider {
      width: 1px; height: 20px;
      background: rgba(255,255,255,0.1);
      flex-shrink: 0;
      display: none;
    }
    @media (min-width: 640px) { .lab-divider { display: block; } }

    /* Editable challenge title */
    .lab-title-group {
      display: flex; align-items: center; gap: 6px;
      flex: 1; min-width: 0;
    }
    .lab-title-input {
      background: transparent;
      border: none;
      font-size: 13px;
      font-weight: 600;
      color: rgba(255,255,255,0.9);
      outline: none;
      padding: 3px 6px;
      border-radius: 4px;
      transition: background 140ms;
      min-width: 0;
      max-width: 220px;
      font-family: inherit;
    }
    .lab-title-input:focus { background: rgba(255,255,255,0.07); }
    .lab-title-input::placeholder { color: rgba(255,255,255,0.25); }
    .lab-save-indicator {
      font-size: 10px;
      color: rgba(0, 212, 168, 0.7);
      white-space: nowrap;
      transition: opacity 300ms;
    }

    /* View-mode buttons */
    .lab-viewbtns {
      display: flex;
      align-items: center;
      gap: 2px;
      flex-wrap: wrap;
    }
    .lab-sep {
      width: 1px; height: 16px;
      background: rgba(255,255,255,0.12);
      margin: 0 4px;
    }
    .view-btn {
      padding: 5px 10px;
      border-radius: 6px;
      border: 1px solid transparent;
      background: transparent;
      color: rgba(255,255,255,0.45);
      font-size: 11px;
      font-weight: 500;
      cursor: pointer;
      transition: color 120ms, background 120ms, border-color 120ms;
      font-family: inherit;
      white-space: nowrap;
    }
    .view-btn:hover {
      color: rgba(255,255,255,0.9);
      background: rgba(255,255,255,0.07);
    }
    .view-btn[data-active="true"] {
      color: #00d4a8;
      background: rgba(0,212,168,0.1);
      border-color: rgba(0,212,168,0.25);
    }

    /* Sub-toolbar (Focus / Compare) */
    .lab-sub-toolbar {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 6px 16px;
      border-top: 1px solid rgba(255,255,255,0.07);
      background: rgba(0,0,0,0.3);
      font-size: 12px;
    }
    .lab-sub-toolbar.flex { display: flex; }
    .lab-sub-label { color: rgba(255,255,255,0.4); }
    .lab-select {
      background: rgba(0,0,0,0.5);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 5px;
      padding: 3px 8px;
      color: rgba(255,255,255,0.8);
      font-size: 11px;
      font-family: inherit;
      outline: none;
    }
  </style>

  <!-- ─────── Starfield for the lab page (same as landing, slightly dimmer) ─────── -->
  <script is:inline>
    /**
     * White dot starfield for the lab view. Opacity is lower than the landing
     * page (0.35 max vs 0.9) so it stays subtle behind the content-heavy grid.
     */
    (function () {
      const COUNT = 140;
      const canvas = document.getElementById('lab-stars');
      if (!(canvas instanceof HTMLCanvasElement)) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      let W = 0, H = 0;
      function makeStar() {
        return {
          x:     Math.random(),
          y:     Math.random(),
          r:     0.4 + Math.random() * 1.1,
          phase: Math.random() * Math.PI * 2,
          freq:  0.0003 + Math.random() * 0.0009,
          base:  0.08 + Math.random() * 0.28,
        };
      }
      const stars = Array.from({ length: COUNT }, makeStar);

      function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize, { passive: true });

      function frame(ts) {
        ctx.clearRect(0, 0, W, H);
        for (const s of stars) {
          const alpha = s.base * (0.4 + 0.6 * Math.sin(s.phase + ts * s.freq));
          ctx.globalAlpha = Math.max(0, alpha);
          ctx.fillStyle = '#ffffff';
          ctx.beginPath();
          ctx.arc(s.x * W, s.y * H, s.r, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
        requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    })();
  </script>
</Layout>
