      font-family: inherit;
      outline: none;
    }

    /* ══════════════════════════════════════════════════════════════════
     *  Cinema Mode — fullscreen grid of ALL instances
     *
     *  Hierarchy:
     *    .cinema-overlay          Fixed fullscreen backdrop (z-index 9999)
     *      .cinema-header         Top bar with title, info, close button
     *      .cinema-body           Flex child that fills remaining viewport
     *        .cinema-logo         Centered watermark behind the grid
     *        .cinema-grid         CSS Grid with --cinema-cols × --cinema-rows
     *          .cinema-card ×N    One per active instance
     *            .cinema-card-label   Name + index badge
     *            .cinema-iframe-wrap  Contains the sandboxed iframe
     *
     *  The grid uses CSS custom properties (--cinema-cols, --cinema-rows)
     *  set by JS to size every card proportionally so they fill 100% of
     *  the available viewport — no scrollbar, every card fully visible.
     * ══════════════════════════════════════════════════════════════════ */

    /* ── Overlay: covers the entire screen ──
     * Uses explicit 100vw/100vh so it fills the viewport even before
     * the Fullscreen API kicks in. In fullscreen the browser overrides
     * dimensions anyway, so this is a safe fallback. */
    .cinema-overlay {
      position: fixed;
      top: 0; left: 0;
      width: 100vw;
      height: 100vh;
      z-index: 9999;
      background: #050505;
      display: flex;
      flex-direction: column;
      opacity: 0;
      transition: opacity 280ms ease;
    }
    .cinema-overlay.open { opacity: 1; }

    /* ── Header bar ── */
    .cinema-header {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 8px 20px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      background: rgba(0,0,0,0.7);
      flex-shrink: 0;
      z-index: 2;
    }
    /* Logo in the cinema header bar */
    .cinema-header-logo {
      height: 22px;
      width: auto;
      flex-shrink: 0;
      opacity: 0.9;
    }
    .cinema-brand {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: #00d4a8;
      flex-shrink: 0;
    }
    .cinema-reto {
      font-size: 14px;
      font-weight: 600;
      color: #fff;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
    }
    .cinema-info {
      font-size: 11px;
      color: rgba(255,255,255,0.4);
      font-family: 'JetBrains Mono', monospace;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .cinema-header-actions {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }
    .cinema-hint {
      font-size: 11px;
      color: rgba(255,255,255,0.25);
      white-space: nowrap;
    }
    .cinema-close-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 6px;
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.06);
      color: rgba(255,255,255,0.6);
      font-size: 11px;
      font-weight: 500;
      font-family: inherit;
      cursor: pointer;
      transition: background 140ms, color 140ms;
    }
    .cinema-close-btn:hover {
      background: rgba(255,255,255,0.12);
      color: #fff;
    }

    /* ── Body wrapper: holds logo + grid, fills all remaining height ──
     * flex:1 + min-height:0 lets this element consume whatever space
     * the header doesn't use. position:relative creates the containing
     * block for the absolutely-positioned grid and logo. */
    .cinema-body {
      flex: 1;
      position: relative;
      min-height: 0;
      overflow: hidden;
    }

    /* ── Centered logo watermark ──
     * Sits behind the grid (z-index: 0) with low opacity so it acts
     * as a subtle branded background visible through the card gaps. */
    .cinema-logo {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: clamp(80px, 12vw, 160px);
      height: auto;
      opacity: 0.06;
      pointer-events: none;
      z-index: 0;
      filter: grayscale(0.3);
    }

    /* ── Grid of cards ──
     * IMPORTANT: The grid is absolutely positioned (inset:0) inside
     * .cinema-body so it fills 100% of the available space without
     * relying on percentage heights (which don't resolve against
     * flex-computed sizes). This guarantees the grid always matches
     * the body wrapper dimensions exactly.
     *
     * --cinema-cols and --cinema-rows are set by JS based on instance
     * count. Every card gets an equal `1fr` share of both axes so all
     * cards are proportionally sized and fill the entire screen. */
    .cinema-grid {
      --cinema-cols: 3;
      --cinema-rows: 2;
      position: absolute;
      inset: 0;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(var(--cinema-cols), 1fr);
      grid-template-rows:    repeat(var(--cinema-rows), 1fr);
      gap: 8px;
      padding: 8px;
    }

    /* ── Individual card ──
     * IMPORTANT: All .cinema-card* selectors use :global() because
     * these elements are created dynamically by JavaScript, NOT by
     * Astro's template engine. Without :global(), Astro's scoped
     * styles add [data-astro-cid-xxx] to the selector, which won't
     * match the JS-created elements. We scope under .cinema-grid
     * (which IS in the template) for safety. */
    .cinema-grid :global(.cinema-card) {
      display: flex;
      flex-direction: column;
      border-radius: 10px;
      border: 2px solid rgba(255,255,255,0.07);
      background: rgba(255,255,255,0.03);
      overflow: hidden;
      min-height: 0;
      transition: border-color 200ms ease, box-shadow 200ms ease;
    }
    /* Focused card: teal border + soft outer glow */
    .cinema-grid :global(.cinema-card.focused) {
      border-color: #00d4a8;
      box-shadow: 0 0 0 1px #00d4a8, 0 0 30px rgba(0,212,168,0.12);
    }

    /* Label bar inside each card */
    .cinema-grid :global(.cinema-card-label) {
      padding: 5px 12px;
      font-size: 12px;
      font-weight: 600;
      color: rgba(255,255,255,0.85);
      background: rgba(0,0,0,0.55);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }
    /* Monospace instance number badge */
    .cinema-grid :global(.cinema-card-num) {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      font-weight: 700;
      color: #00d4a8;
      letter-spacing: .08em;
    }

    /* Iframe wrapper: takes all remaining card height */
    .cinema-grid :global(.cinema-iframe-wrap) {
      flex: 1;
      min-height: 0;
      position: relative;
    }
    /* Iframe stretches to fill its wrapper via absolute positioning */
    .cinema-grid :global(.cinema-iframe-wrap iframe) {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
      background: #fff;
    }
  </style>

  <!-- ─────── Starfield for the lab page (same as landing, slightly dimmer) ─────── -->
  <script is:inline>
    /**
     * White dot starfield for the lab view. Opacity is lower than the landing
     * page (0.35 max vs 0.9) so it stays subtle behind the content-heavy grid.
     */
    (function () {
      const COUNT = 140;
      const canvas = document.getElementById('lab-stars');
      if (!(canvas instanceof HTMLCanvasElement)) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      let W = 0, H = 0;
      function makeStar() {
        return {
          x:     Math.random(),
          y:     Math.random(),
          r:     0.4 + Math.random() * 1.1,
          phase: Math.random() * Math.PI * 2,
          freq:  0.0003 + Math.random() * 0.0009,
          base:  0.08 + Math.random() * 0.28,
        };
      }
      const stars = Array.from({ length: COUNT }, makeStar);

      function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize, { passive: true });

      function frame(ts) {
        ctx.clearRect(0, 0, W, H);
        for (const s of stars) {
          const alpha = s.base * (0.4 + 0.6 * Math.sin(s.phase + ts * s.freq));
          ctx.globalAlpha = Math.max(0, alpha);
          ctx.fillStyle = '#ffffff';
          ctx.beginPath();
          ctx.arc(s.x * W, s.y * H, s.r, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
        requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    })();
  </script>
</Layout>
